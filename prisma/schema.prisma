generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id           String   @id @default(uuid())
  name         String
  handle       String
  role         String
  affiliation  String
  backstory    String
  avatarSeed   Int
  stats        Json
  derivedStats Json
  roleAbility  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
